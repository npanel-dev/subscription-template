{{- $sortFields := list "Sort" "Port" "Name" -}}
{{- $sortConfig := dict "Sort" "asc" "Port" "asc" "Name" "asc" -}}
{{- $byKey := dict -}}
{{- range $p := .Proxies -}}
  {{- $keyParts := list -}}
  {{- range $field := $sortFields -}}
    {{- $order := index $sortConfig $field -}}
    {{- $val := default "" (printf "%v" (index $p $field)) -}}
    {{- if or (eq $field "Sort") (eq $field "Port") -}}
      {{- $val = printf "%08d" (int (default 0 (index $p $field))) -}}
    {{- end -}}
    {{- if eq $order "desc" -}}
      {{- $val = printf "~%s" $val -}}
    {{- end -}}
    {{- $keyParts = append $keyParts $val -}}
  {{- end -}}
  {{- $_ := set $byKey (join "|" $keyParts) $p -}}
{{- end -}}
{{- $sorted := list -}}
{{- range $k := sortAlpha (keys $byKey) -}}
  {{- $sorted = append $sorted (index $byKey $k) -}}
{{- end -}}

{{- $supportSet := dict "shadowsocks" true "vmess" true "vless" true "trojan" true "hysteria2" true "hysteria" true -}}
{{- range $proxy := $sorted -}}
{{- $proxyType := lower (default "" $proxy.Type) -}}
{{- if hasKey $supportSet $proxyType -}}
{{- $server := $proxy.Server -}}
{{- if and (contains $server ":") (not (hasPrefix "[" $server)) -}}
  {{- $server = printf "[%s]" $server -}}
{{- end -}}
{{- $password := $.UserInfo.Password -}}
{{- if and (eq $proxyType "shadowsocks") (ne (default "" $proxy.ServerKey) "") -}}
  {{- $method := default "" $proxy.Method -}}
  {{- if or (hasPrefix "2022-blake3-" $method) (eq $method "2022-blake3-aes-128-gcm") (eq $method "2022-blake3-aes-256-gcm") -}}
    {{- $userKeyLen := ternary 16 32 (hasSuffix "128-gcm" $method) -}}
    {{- $pwdStr := printf "%s" $password -}}
    {{- $userKey := ternary $pwdStr (trunc $userKeyLen $pwdStr) (le (len $pwdStr) $userKeyLen) -}}
    {{- $serverB64 := b64enc $proxy.ServerKey -}}
    {{- $userB64 := b64enc $userKey -}}
    {{- $password = printf "%s:%s" $serverB64 $userB64 -}}
  {{- end -}}
{{- end -}}
{{- $transport := lower (default "tcp" $proxy.Transport) -}}
{{- if eq $transport "websocket" -}}
  {{- $transport = "ws" -}}
{{- end -}}
{{- if or (eq $transport "") (eq $transport "tcp") -}}
  {{- $transport = "tcp" -}}
{{- end -}}
{{- $sni := default "" $proxy.SNI -}}
{{- if eq $sni "" -}}
  {{- $sni = default "" $proxy.Host -}}
{{- end -}}
{{- if and (eq $sni "") (not (or (regexMatch `^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$` $proxy.Server) (contains $proxy.Server ":"))) -}}
  {{- $sni = $proxy.Server -}}
{{- end -}}
{{- $securityParams := dict -}}
{{- if or (eq $proxy.Security "tls") (eq $proxy.Security "reality") -}}
  {{- $_ := set $securityParams "security" $proxy.Security -}}
{{- end -}}
{{- if ne $sni "" -}}
  {{- $_ := set $securityParams "sni" $sni -}}
{{- end -}}
{{- if $proxy.AllowInsecure -}}
  {{- $_ := set $securityParams "allowInsecure" "1" -}}
{{- end -}}
{{- if ne (default "" $proxy.Fingerprint) "" -}}
  {{- $_ := set $securityParams "fp" $proxy.Fingerprint -}}
{{- end -}}
{{- if and (eq $proxy.Security "reality") (ne (default "" $proxy.RealityPublicKey) "") -}}
  {{- $_ := set $securityParams "pbk" $proxy.RealityPublicKey -}}
{{- end -}}
{{- if and (eq $proxy.Security "reality") (ne (default "" $proxy.RealityShortId) "") -}}
  {{- $_ := set $securityParams "sid" $proxy.RealityShortId -}}
{{- end -}}
{{- $transportParams := dict -}}
{{- if and (ne $transport "") (not (or (eq $transport "tcp") (eq $transport "raw"))) -}}
  {{- $_ := set $transportParams "type" $transport -}}
{{- end -}}
{{- if and (or (eq $transport "ws") (eq $transport "httpupgrade") (eq $transport "xhttp")) (ne (default "" $proxy.Host) "") -}}
  {{- $_ := set $transportParams "host" $proxy.Host -}}
{{- end -}}
{{- if and (or (eq $transport "ws") (eq $transport "httpupgrade") (eq $transport "xhttp")) (ne (default "" $proxy.Path) "") -}}
  {{- $_ := set $transportParams "path" ($proxy.Path | urlquery) -}}
{{- end -}}
{{- if and (eq $transport "grpc") (ne (default "" $proxy.ServiceName) "") -}}
  {{- $_ := set $transportParams "serviceName" $proxy.ServiceName -}}
{{- end -}}
{{- if eq $proxyType "shadowsocks" }}
{{- $params := list "udp=1" "tfo=1" -}}
ss://{{ printf "%s:%s" (default "aes-128-gcm" $proxy.Method) $password | b64enc }}@{{ $server }}:{{ $proxy.Port }}?{{ join "&" $params }}#{{ $proxy.Name | urlquery }}{{ "\n" }}
{{- else if eq $proxyType "vmess" }}
{{- $vmess := dict "v" "2" "ps" $proxy.Name "add" $proxy.Server "port" (printf "%d" $proxy.Port) "id" $password "aid" "0" "scy" "auto" "net" "tcp" "type" "none" -}}
{{- if hasKey $transportParams "type" -}}
  {{- $_ := set $vmess "net" (index $transportParams "type") -}}
{{- end -}}
{{- if hasKey $transportParams "host" -}}
  {{- $_ := set $vmess "host" (index $transportParams "host") -}}
{{- end -}}
{{- if ne (default "" $proxy.Path) "" -}}
  {{- $_ := set $vmess "path" $proxy.Path -}}
{{- end -}}
{{- if and (eq $transport "grpc") (hasKey $transportParams "serviceName") -}}
  {{- $_ := set $vmess "path" (index $transportParams "serviceName") -}}
{{- end -}}
{{- if hasKey $securityParams "security" -}}
  {{- $_ := set $vmess "tls" (index $securityParams "security") -}}
{{- end -}}
{{- if hasKey $securityParams "sni" -}}
  {{- $_ := set $vmess "sni" (index $securityParams "sni") -}}
{{- end -}}
{{- if hasKey $securityParams "fp" -}}
  {{- $_ := set $vmess "fp" (index $securityParams "fp") -}}
{{- end -}}
{{- if hasKey $securityParams "allowInsecure" -}}
  {{- $_ := set $vmess "allowInsecure" true -}}
{{- end }}
vmess://{{ $vmess | toJson | b64enc }}{{ "\n" }}
{{- else if eq $proxyType "vless" }}
{{- $params := list "encryption=none" -}}
{{- if and (ne (default "" $proxy.Flow) "") (ne $proxy.Flow "none") -}}
  {{- $params = append $params (printf "flow=%s" $proxy.Flow) -}}
{{- end -}}
{{- range $key, $val := $securityParams -}}
  {{- $params = append $params (printf "%s=%s" $key $val) -}}
{{- end -}}
{{- range $key, $val := $transportParams -}}
  {{- $params = append $params (printf "%s=%s" $key $val) -}}
{{- end -}}
{{- $params = append $params "udp=1" -}}
{{- $params = append $params "tfo=1" -}}
vless://{{ $password }}@{{ $server }}:{{ $proxy.Port }}?{{ join "&" $params }}#{{ $proxy.Name | urlquery }}{{ "\n" }}
{{- else if eq $proxyType "trojan" }}
{{- $params := list -}}
{{- range $key, $val := $securityParams -}}
  {{- $params = append $params (printf "%s=%s" $key $val) -}}
{{- end -}}
{{- range $key, $val := $transportParams -}}
  {{- $params = append $params (printf "%s=%s" $key $val) -}}
{{- end -}}
{{- $params = append $params "udp=1" -}}
{{- $params = append $params "tfo=1" -}}
trojan://{{ $password }}@{{ $server }}:{{ $proxy.Port }}?{{ join "&" $params }}#{{ $proxy.Name | urlquery }}{{ "\n" }}
{{- else if or (eq $proxyType "hysteria2") (eq $proxyType "hysteria") }}
{{- $params := list -}}
{{- if ne $sni "" -}}
  {{- $params = append $params (printf "sni=%s" $sni) -}}
{{- end -}}
{{- if $proxy.AllowInsecure -}}
  {{- $params = append $params "insecure=1" -}}
{{- end -}}
{{- if ne (default "" $proxy.ObfsPassword) "" -}}
  {{- $params = append $params "obfs=salamander" -}}
  {{- $params = append $params (printf "obfs-password=%s" ($proxy.ObfsPassword | urlquery)) -}}
{{- end -}}
{{- if ne (default "" $proxy.HopPorts) "" -}}
  {{- $params = append $params (printf "mport=%s" ($proxy.HopPorts | urlquery)) -}}
{{- end -}}
{{- $params = append $params "udp=1" -}}
{{- $params = append $params "tfo=1" -}}
hysteria2://{{ $password }}@{{ $server }}:{{ $proxy.Port }}?{{ join "&" $params }}#{{ $proxy.Name | urlquery }}{{ "\n" }}
{{- end -}}
{{- end -}}
{{- end -}}
